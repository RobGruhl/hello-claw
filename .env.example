# Slack Bot OAuth Token (xoxb-...)
SLACK_BOT_TOKEN=

# Slack App-Level Token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=

# Anthropic API Key (set here or in ~/.anthropic/api_key)
ANTHROPIC_API_KEY=

# Optional: Gemini API key for image generation
GEMINI_API_KEY=

# Optional: Perplexity API key for web search & research
PERPLEXITY_API_KEY=

# Optional: GitHub fine-grained PAT for issue tracking (scoped to your repo, Issues read/write)
GH_TOKEN=

# Optional: GitHub repo (owner/repo) — auto-detected from git remote if unset
GH_REPO=

# Optional: OpenAI API key for oracle tool (GPT-5 Pro background queries)
OPENAI_API_KEY=

# Optional: ElevenLabs API key for voice synthesis (TTS)
ELEVENLABS_API_KEY=

# Optional: ElevenLabs voice ID (defaults to built-in if unset)
ELEVENLABS_VOICE_ID=

# Optional: Channel ID for autonomous heartbeat check-ins
HEARTBEAT_CHANNEL=

# Optional: HTTP proxy for SDK API call debugging (e.g., http://localhost:8080)
API_LOG_PROXY=

# Agent identity (used in system prompt and workspace)
AGENT_NAME=
AGENT_PRONOUNS=

# Human identity (used in prompts — falls back to "the user" if unset)
USER_NAME=

# Optional: Firecrawl API key for web scraping
FIRECRAWL_API_KEY=

# Deploy target hostname (used by deploy procedures)
MINI_HOST=

# --- Cost Controls (frugal defaults for the OSS release) ---
# Daily spending limit — auto-pauses agent when exceeded (default: $3)
# MAX_DAILY_BUDGET_USD=3
# Per-session budget cap via SDK maxBudgetUsd (default: $50)
# MAX_SESSION_BUDGET_USD=50
# Heartbeat schedule: conservative (4/day), standard (8/day), off (default: off)
# HEARTBEAT_MODE=off
# Primary model for interactive + flagship heartbeats (default: claude-sonnet-4-6)
# AGENT_MODEL=claude-sonnet-4-6
# Reasoning effort: low | medium | high | max (default: high)
# AGENT_EFFORT=high
# Model for scheduled cron tasks (default: same as AGENT_MODEL)
# CRON_MODEL=
# IANA timezone for all agent-facing timestamps and the 4am daily reset
# (default: America/Los_Angeles)
# AGENT_TIMEZONE=America/Los_Angeles

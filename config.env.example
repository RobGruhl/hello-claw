# hello-claw — Deployment Configuration
# Fill in all values, then place alongside the bootstrap zip as 'config.env'.
# setup.sh will consume this file and delete it after installation.

# === API Secrets (required) ===
ANTHROPIC_API_KEY=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# === API Secrets (optional) ===
# Enables image generation via Gemini
GEMINI_API_KEY=
# Enables web search, AI answers, deep research, and reasoning via Perplexity
PERPLEXITY_API_KEY=
# Enables GitHub issue tracking (fine-grained PAT, Issues + Contents read-only + Metadata)
GH_TOKEN=
# Enables oracle tool (GPT-5 Pro background queries)
OPENAI_API_KEY=
# Enables voice synthesis (ElevenLabs TTS)
ELEVENLABS_API_KEY=
# ElevenLabs voice ID (defaults to built-in if unset)
ELEVENLABS_VOICE_ID=
# Enables web scraping (Firecrawl API)
FIRECRAWL_API_KEY=

# === Slack App Requirements ===
# Your Slack app must have these additional configurations:
# Bot Token Scopes: reactions:read (in addition to chat:write, files:write, reactions:write, channels:read, groups:read, channels:history, groups:history)
# Event Subscriptions: reaction_added (in addition to message.channels, message.groups)
# These are required for the cron task and GitHub write approval workflow (approve/reject via emoji reactions).

# === System Identity ===
# Hostname for the Mac Mini (sets ComputerName + LocalHostName -> X.local)
MINI_HOSTNAME=

# Agent identity (used in system prompt and workspace)
AGENT_NAME=
AGENT_PRONOUNS=

# Human identity (used in prompts — falls back to "the user" if unset)
USER_NAME=

# Channel ID for autonomous heartbeat check-ins
HEARTBEAT_CHANNEL=

# === SSH Access ===
# Public key to add to authorized_keys (for remote access from control machine)
# Get yours with: cat ~/.ssh/id_ed25519.pub
SSH_AUTHORIZED_KEY=

# === Cost Controls (conservative defaults protect your wallet) ===
# Daily spending limit — auto-pauses agent when exceeded (default: $5)
# MAX_DAILY_BUDGET_USD=5
# Per-session budget cap via SDK maxBudgetUsd (default: $50)
# MAX_SESSION_BUDGET_USD=50
# Enable 1M token context window (2x pricing surcharge, default: disabled)
# ENABLE_1M_CONTEXT=false
# Heartbeat mode: conservative (4/day), standard (8/day), off (default: conservative)
# HEARTBEAT_MODE=conservative
# Model (default: claude-opus-4-6)
# AGENT_MODEL=claude-opus-4-6

# === Network Identity ===
# Used by /deploy slash command and documented procedures
MINI_HOST=
